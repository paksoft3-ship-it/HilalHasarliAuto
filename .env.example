# ─────────────────────────────────────────────────────────────
# OTO NAKİT — environment variables
# Copy to .env.local for development. Never commit real secrets.
# All NEXT_PUBLIC_* values are exposed to the browser.
# ─────────────────────────────────────────────────────────────

# Brand & contact (later editable via Admin → Settings)
NEXT_PUBLIC_BRAND_NAME="Hasarlı Araç Alan"
NEXT_PUBLIC_DOMAIN="https://hasarliaracalan.com"
NEXT_PUBLIC_PHONE_DISPLAY="0850 302 16 16"
NEXT_PUBLIC_PHONE_E164="+908503021616"
NEXT_PUBLIC_WHATSAPP_E164="+905555555555"
NEXT_PUBLIC_EMAIL="info@hasarliaracalan.com"
NEXT_PUBLIC_WORKING_HOURS="7/24 İletişim"

# Legal / company (shown only where real data exists)
NEXT_PUBLIC_LEGAL_COMPANY_NAME=""
NEXT_PUBLIC_COMPANY_ADDRESS=""
NEXT_PUBLIC_TAX_INFO=""
NEXT_PUBLIC_MERSIS=""
NEXT_PUBLIC_KEP=""

# Database (Neon PostgreSQL via Vercel Marketplace)
# When set, forms persist leads. Run: pnpm db:migrate && pnpm db:seed
DATABASE_URL=""

# Initial super-admin (used by pnpm db:seed)
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD=""

# Storage (Vercel Blob) — Phase 1+
# BLOB_READ_WRITE_TOKEN=""

# Tracking & analytics (all optional; layer loads only when set)
NEXT_PUBLIC_GTM_ID=""
NEXT_PUBLIC_GA4_ID=""
NEXT_PUBLIC_GOOGLE_ADS_ID=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.posthog.com"

# WhatsApp Business Cloud API (server-only). Empty = mock/test mode.
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_APP_SECRET=""
WHATSAPP_API_VERSION="v21.0"
WHATSAPP_STAFF_RECIPIENTS=""   # comma-separated staff numbers for new-lead alerts

# Call tracking (provider-agnostic). Default mock provider.
CALL_PROVIDER="mock"
CALL_WEBHOOK_SECRET=""
CALL_QUALIFIED_THRESHOLD_SEC="60"

# Bot protection (Cloudflare Turnstile) — optional; enforced when secret is set
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET=""
